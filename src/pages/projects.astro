---
import PageLayout from "@/layouts/Base.astro";
import ProjectCard from "@/components/ProjectCard.astro";

const meta = {
  description: "Projects and tooling around Kubernetes, Cloud Native, and platform automation.",
  title: "Projects",
};

interface Project {
  name: string;
  description: string;
  link: string;
  tags: string[];
  private: boolean;
  active?: boolean;
  category: "production" | "exploration";
}

const projects: Project[] = [
  {
    name: "dbalance-kopf",
    description:
      "DBalance Operator & DBalance plugin for managing HAProxy load balancer configurations via DBalance API using Python3 & Kopf",
    link: "https://github.com/febri4n",
    tags: ["Python", "Kopf", "Kubernetes Operator", "HAProxy", "REST API"],
    private: true,
    active: true,
    category: "production",
  },
  {
    name: "dbalance-ingress-haproxy",
    description:
      "A Helm chart for installing HAProxy Ingress Controller with automatic DBalance LoadBalancer integration",
    link: "https://github.com/febri4n",
    tags: ["Helm", "HAProxy Ingress", "Kubernetes", "LoadBalancer"],
    private: true,
    active: true,
    category: "production",
  },
  {
    name: "kubectl-dbalance",
    description:
      "A kubectl plugin for managing dbalance load balancers directly from kubectl",
    link: "https://github.com/febri4n",
    tags: ["Go", "kubectl-plugin", "Kubernetes", "CLI"],
    private: true,
    active: true,
    category: "production",
  },
  {
    name: "rancherctl",
    description:
      "CLI untuk mengelola Rancher via API — terinspirasi dari kubectl",
    link: "https://github.com/febri4n",
    tags: ["Go", "CLI", "Rancher", "Kubernetes", "REST API"],
    private: true,
    active: true,
    category: "production",
  },
  {
    name: "kubeconfig-manager",
    description:
      "Manage kubeconfig file with fzf — switching Kubernetes context lebih cepat",
    link: "https://github.com/febri4n",
    tags: ["Shell", "fzf", "Kubernetes", "CLI"],
    private: false,
    category: "production",
  },
  {
    name: "rancher-custom-metrics-exporter",
    description:
      "Custom metrics exporter built with Go that collects real-time metrics from multiple Rancher downstream clusters",
    link: "https://github.com/febri4n",
    tags: ["Go", "Prometheus", "Rancher", "Kubernetes", "Metrics"],
    private: true,
    active: true,
    category: "production",
  },
  {
    name: "loker.febri4n.my.id",
    description:
      "Aggregator lowongan IT/Cloud/DevOps dari Glints, Indeed, Kalibrr, Dealls — auto-scrape tiap hari pakai Firecrawl + GitHub Actions",
    link: "https://loker.febri4n.my.id",
    tags: ["Astro", "Python", "Firecrawl", "SQLite", "Cloudflare Pages"],
    private: false,
    category: "exploration",
  },
];

const productionProjects = projects.filter((p) => p.category === "production");
const explorationProjects = projects.filter((p) => p.category === "exploration");
const publicCount = projects.filter((p) => !p.private).length;
const privateCount = projects.filter((p) => p.private).length;
const heroLabel = `${projects.length} Projects · ${publicCount} Public · ${privateCount} Private`;
---

<PageLayout meta={meta}>
  <!-- Hero -->
  <section class="mb-10 mt-4">
    <div class="flex flex-col gap-4">
      <div class="mb-1 flex items-center gap-2">
        <span class="inline-block h-3 w-3 animate-pulse rounded-full bg-green-400" />
        <span class="text-xs font-medium text-green-600 dark:text-green-400">{heroLabel}</span>
      </div>
      <h1 class="title text-3xl font-bold leading-tight sm:text-4xl">
        🚀 <span class="text-accent">Projects</span>
      </h1>
      <p class="max-w-xl text-sm leading-relaxed text-textColor/70">
        Tooling, operator, dan automation seputar Kubernetes,
        Cloud Native, dan platform engineering.
      </p>
    </div>
  </section>

  <!-- Production Projects -->
  <section class="mb-10">
    <div class="mb-1 flex items-center gap-2">
      <h2 class="text-lg font-semibold text-textColor">🔥 Production</h2>
      <span class="text-xs text-textColor/50">({productionProjects.length})</span>
    </div>
    <p class="mb-5 text-sm text-textColor/60">
      Project yang aktif dipakai di production environment
    </p>

    <div class="grid gap-4 sm:grid-cols-2">
      {productionProjects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>

  <!-- Exploration Projects -->
  <section class="mb-10">
    <div class="mb-1 flex items-center gap-2">
      <h2 class="text-lg font-semibold text-textColor">🧪 Exploration</h2>
      <span class="text-xs text-textColor/50">({explorationProjects.length})</span>
    </div>
    <p class="mb-5 text-sm text-textColor/60">
      Project pembelajaran dan eksperimen pribadi
    </p>

    <div class="grid gap-4 sm:grid-cols-2">
      {explorationProjects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>
</PageLayout>
