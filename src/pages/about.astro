---

<PageLayout meta={meta}>
  <!-- Hero -->
  <section class="mb-10 mt-4">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex-1">
        <div class="mb-2 flex items-center gap-2">
          <span class="inline-block h-3 w-3 animate-pulse rounded-full bg-green-400" />
          <span class="text-xs font-medium text-green-600 dark:text-green-400"
            >Kubestronaut 🏆</span
          >
        </div>
        <h1 class="title mb-3 text-3xl font-bold leading-tight sm:text-4xl">
          About <span class="text-accent">Me</span>
        </h1>
        <p class="max-w-xl text-sm leading-relaxed text-textColor/70">
          Kubernetes certified engineer with deep expertise in cloud-native
          architectures, multi-cluster Kubernetes, and platform automation.
        </p>
      </div>
      <div class="flex-shrink-0">
        <img
          src="/avatar.jpg"
          alt="Febri4n avatar"
          class="h-24 w-24 rounded-2xl object-cover sm:h-28 sm:w-28"
        />
      </div>
    </div>
  </section>

  <!-- Bio -->
  <section class="mb-12">
    <div
      class="rounded-xl border border-accent/10 bg-accent/5 p-6 leading-relaxed"
    >
      <p class="mb-3">
        <strong>Halo!</strong> Saya
        <strong class="text-accent">Solihin Febrian Saputra</strong> —
        seorang Cloud Engineer dengan fokus utama di ekosistem
        <strong>Kubernetes</strong> dan teknologi <strong>Cloud Native</strong>.
      </p>
      <p class="mb-3">
        Saya memiliki pengalaman hands-on yang kuat dalam membangun dan
        mengoperasikan platform production-ready menggunakan teknologi CNCF,
        observability tooling, dan workflow GitOps di atas infrastruktur
        OpenStack dan hybrid cloud.
      </p>
      <p class="text-textColor/70">
        Blog ini adalah tempat saya mendokumentasikan catatan, tutorial, dan
        temuan seputar Cloud, DevOps, Linux — dari pengalaman belajar dan
        ngulik sehari-hari.
      </p>
    </div>
  </section>

  <!-- Kubestronaut Highlight -->
  <section class="mb-12">
    <div
      class="relative overflow-hidden rounded-xl border border-yellow-500/30 bg-gradient-to-br from-yellow-500/10 via-transparent to-yellow-600/5 p-6"
    >
      <div class="flex flex-col items-center gap-4 sm:flex-row">
        <a
          href={kubestronaut.badgeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex-shrink-0 transition-transform hover:scale-105"
        >
          <img
            src={kubestronaut.imageUrl}
            alt={kubestronaut.name}
            class="h-20 w-20 sm:h-24 sm:w-24"
          />
        </a>
        <div>
          <div class="mb-1 flex items-center gap-2">
            <h3 class="text-lg font-bold text-yellow-600 dark:text-yellow-400">
              {kubestronaut.name}
            </h3>
            <span class="rounded-full bg-yellow-500/20 px-2 py-0.5 text-xs font-medium text-yellow-600 dark:text-yellow-400"
              >🏆 Pencapaian Tertinggi</span
            >
          </div>
          <p class="text-sm text-textColor/80">
            Salah satu dari sedikit praktisi Kubernetes di Indonesia yang
            berhasil meraih gelar Kubestronaut — dengan menyelesaikan
            <strong>5 sertifikasi Kubernetes resmi</strong> dari Cloud Native
            Computing Foundation (CNCF).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Kubernetes Certifications -->
  <section class="mb-10">
    <h2 class="title mb-1 text-lg font-semibold">
      ☸️ Kubernetes Certifications
    </h2>
    <p class="mb-5 text-sm text-textColor/60">
      Sertifikasi resmi dari CNCF / The Linux Foundation
    </p>

    <div
      class="grid gap-4 sm:grid-cols-2"
    >
      {certBadges
        .filter((b) =>
          ["cks", "cka", "ckad", "kcsa", "kcna"].includes(b.id)
        )
        .map((badge) => (
          <a
            href={badge.badgeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 rounded-lg border border-accent/10 bg-accent/5 p-4 transition-all hover:border-accent/30 hover:shadow-sm"
          >
            <img
              src={badge.imageUrl}
              alt={badge.name}
              class="h-14 w-14 flex-shrink-0 sm:h-16 sm:w-16"
            />
            <div class="min-w-0">
              <p class="font-semibold text-textColor">{badge.name}</p>
              <p class="text-xs text-textColor/60">{badge.fullName}</p>
              <p class="mt-0.5 text-xs text-textColor/50">{badge.date}</p>
            </div>
          </a>
        ))}
    </div>
  </section>

  <!-- Other Certifications -->
  <section class="mb-10">
    <h2 class="title mb-1 text-lg font-semibold">
      🎖️ Sertifikasi Lainnya
    </h2>
    <p class="mb-5 text-sm text-textColor/60">
      Red Hat, Google Cloud, SUSE
    </p>

    <div class="grid gap-4 sm:grid-cols-2">
      {certBadges
        .filter((b) => ["rhcsa", "ace", "scds-rke2", "scds-suse-ai"].includes(b.id))
        .map((badge) => (
          <a
            href={badge.badgeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 rounded-lg border border-accent/10 bg-accent/5 p-4 transition-all hover:border-accent/30 hover:shadow-sm"
          >
            <img
              src={badge.imageUrl}
              alt={badge.name}
              class="h-14 w-14 flex-shrink-0 sm:h-16 sm:w-16"
            />
            <div class="min-w-0">
              <p class="font-semibold text-textColor">{badge.name}</p>
              <p class="text-xs text-textColor/60">{badge.fullName}</p>
              <p class="mt-0.5 text-xs text-textColor/50">{badge.date}</p>
            </div>
          </a>
        ))}
    </div>
  </section>

  <!-- Training -->
  <section class="mb-12">
    <h2 class="title mb-1 text-lg font-semibold">📘 Training & Workshop</h2>
    <p class="mb-5 text-sm text-textColor/60">
      The Linux Foundation & Amazon Web Services
    </p>

    <div class="grid gap-4 sm:grid-cols-2">
      {trainingBadges.map((badge) => (
        <a
          href={badge.badgeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 rounded-lg border border-accent/10 bg-accent/5 p-4 transition-all hover:border-accent/30 hover:shadow-sm"
        >
          <img
            src={badge.imageUrl}
            alt={badge.name}
            class="h-14 w-14 flex-shrink-0 sm:h-16 sm:w-16"
          />
          <div class="min-w-0">
            <p class="font-semibold text-textColor">{badge.name}</p>
            <p class="text-xs text-textColor/60">
              {badge.fullName}
            </p>
            <p class="mt-0.5 text-xs text-textColor/50">{badge.date}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</PageLayout>
