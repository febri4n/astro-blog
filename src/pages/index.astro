---
import SocialList from "@/components/SocialList.astro";
import PageLayout from "@/layouts/Base.astro";
import { getAllPosts, sortMDByDate, getUniqueTagsWithCount } from "@/data/post";
import FormattedDate from "@/components/FormattedDate.astro";
import { Icon } from "astro-icon/components";

const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts);
const latestPosts = allPostsByDate.slice(0, MAX_POSTS);
const featured = allPostsByDate[0]; // Latest post as featured
const tagsWithCount = getUniqueTagsWithCount(allPosts).slice(0, 12);
const totalPosts = allPosts.length;
const totalTags = tagsWithCount.length;
const totalReadingTime = totalPosts * 5;

const certs = [
  {
    name: "Kubestronaut",
    issuer: "The Linux Foundation",
    date: "Jan 2026",
    status: "active",
    badgeId: "92e14239-4c92-4b1c-9cec-bba617caa537",
    img: "https://images.credly.com/size/340x340/images/cd6c6449-6814-4613-a2d3-13cf4ac5be4f/image.png",
    highlight: true,
  },
  {
    name: "CKS",
    label: "Certified Kubernetes Security Specialist",
    issuer: "The Linux Foundation",
    date: "Exp Des 2027",
    status: "active",
    badgeId: "aea1ab6e-ee64-4f11-9276-824dfefbc1f5",
    img: "https://images.credly.com/size/340x340/images/9945dfcb-1cca-4529-85e6-db1be3782210/kubernetes-security-specialist-logo2.png",
  },
  {
    name: "CKA",
    label: "Certified Kubernetes Administrator",
    issuer: "The Linux Foundation",
    date: "Exp Jan 2027",
    status: "active",
    badgeId: "390f1458-ec0c-45f5-baa1-f0e19f23fa16",
    img: "https://images.credly.com/size/340x340/images/8b8ed108-e77d-4396-ac59-2504583b9d54/cka_from_cncfsite__281_29.png",
  },
  {
    name: "CKAD",
    label: "Certified Kubernetes Application Developer",
    issuer: "The Linux Foundation",
    date: "Exp Jul 2027",
    status: "active",
    badgeId: "1e1006de-c8b6-4fc6-bc3d-2d507d1d410b",
    img: "https://images.credly.com/size/340x340/images/cc8adc83-1dc6-4d57-8e20-22171247e052/blob",
  },
  {
    name: "KCSA",
    label: "Kubernetes & Cloud Native Security Associate",
    issuer: "The Linux Foundation",
    date: "Exp Okt 2027",
    status: "active",
    badgeId: "dca0f393-75dc-445b-8cdd-7c9eb65c880b",
    img: "https://images.credly.com/size/340x340/images/67dd8a95-8876-4051-9cb9-3d97c204f85a/image.png",
  },
  {
    name: "KCNA",
    label: "Kubernetes & Cloud Native Associate",
    issuer: "The Linux Foundation",
    date: "Exp Sep 2026",
    status: "active",
    badgeId: "b2eded30-8db8-45b9-9c67-106b1a98296a",
    img: "https://images.credly.com/size/340x340/images/f28f1d88-428a-47f6-95b5-7da1dd6c1000/KCNA_badge.png",
  },
  {
    name: "RHCSA",
    label: "Red Hat Certified System Administrator",
    issuer: "Red Hat",
    date: "Exp Jun 2027",
    status: "active",
    badgeId: "290d8ae6-c1a3-41e4-ace9-bac4bb609005",
    img: "https://images.credly.com/size/340x340/images/572de0ba-2c59-4816-a59d-b0e1687e45ee/image.png",
  },
  {
    name: "Associate Cloud Engineer",
    issuer: "Google Cloud",
    date: "Exp Jun 2026",
    status: "active",
    badgeId: "d22be9eb-5b9d-4deb-9aeb-0fc02866f4d0",
    img: "https://images.credly.com/size/340x340/images/08096465-cbfc-4c3e-93e5-93c5aa61f23e/image.png",
  },
  {
    name: "AWS re/Start Graduate",
    issuer: "Amazon Web Services",
    date: "Jan 2026",
    status: "active",
    badgeId: "49430155-c9cd-4235-bbf7-932ee1d97d88",
    img: "https://images.credly.com/size/340x340/images/44e2c252-5d19-4574-9646-005f7225bf53/image.png",
  },
  {
    name: "LFCA",
    label: "Linux Foundation Certified IT Associate",
    issuer: "The Linux Foundation",
    date: "Exp Jan 2026",
    status: "expired",
    badgeId: "4006e966-b08e-4595-b45f-4672cde1356c",
    img: "https://images.credly.com/size/340x340/images/a2c14e0a-56cb-4990-809a-23b0850c1f96/Training_Badges_LFCA_for_acclaim.png",
  },
];
---

<PageLayout meta={{ title: "Home" }}>
	<!-- Hero Section -->
	<section class="relative mb-12 mt-4">
		<div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
			<div class="flex-1">
				<div class="mb-2 flex items-center gap-2">
					<span class="inline-block h-3 w-3 animate-pulse rounded-full bg-green-400"></span>
					<span class="text-xs font-medium text-green-600 dark:text-green-400">Active since 2024</span>
				</div>
				<h1 class="title mb-3 text-3xl font-bold leading-tight sm:text-4xl">
					Hai, Saya <span class="text-accent">Febri4n</span> 👋
				</h1>
				<p class="mb-2 max-w-lg text-textColor/80 leading-relaxed">
					Catatan, tutorial, dan dokumentasi seputar 
					<strong class="text-textColor">Cloud, DevOps &amp; Linux</strong> 
					dari pengalaman belajar sehari-hari.
				</p>
				<p class="mb-4 text-sm text-textColor/60">
					<span class="font-medium text-textColor/80">{totalPosts}</span> tulisan · 
					<span class="font-medium text-textColor/80">{totalTags}</span> topik · 
					±{totalReadingTime} menit bacaan
				</p>
				<SocialList />
			</div>
			<!-- Avatar/logo area -->
			<div class="flex-shrink-0">
				<img
					src="/avatar.jpg"
					alt="Febri4n avatar"
					class="h-24 w-24 rounded-2xl object-cover sm:h-28 sm:w-28"
				/>
			</div>
		</div>
	</section>

	<!-- Stats Bar -->
	<section class="mb-12 grid grid-cols-3 gap-3 sm:gap-4">
		<div class="rounded-xl border border-accent/10 bg-accent/5 p-4 text-center">
			<p class="text-2xl font-bold text-accent sm:text-3xl">{totalPosts}</p>
			<p class="mt-1 text-xs text-textColor/60">Tulisan</p>
		</div>
		<div class="rounded-xl border border-accent/10 bg-accent/5 p-4 text-center">
			<p class="text-2xl font-bold text-accent sm:text-3xl">{totalTags}</p>
			<p class="mt-1 text-xs text-textColor/60">Topik</p>
		</div>
		<div class="rounded-xl border border-accent/10 bg-accent/5 p-4 text-center">
			<p class="text-2xl font-bold text-accent sm:text-3xl">±{totalReadingTime}</p>
			<p class="mt-1 text-xs text-textColor/60">Menit Baca</p>
		</div>
	</section>

	<!-- Certifications Section -->
	<section class="mb-12">
		<h2 class="title mb-4 text-lg font-semibold">🏆 Sertifikasi</h2>
		<p class="mb-5 text-sm text-textColor/60">
			Klik badge untuk verifikasi via Credly
		</p>
		<div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
			{certs.map((cert) => (
				<a
					href={`https://www.credly.com/badges/${cert.badgeId}`}
					target="_blank"
					rel="noopener noreferrer"
					class:list={[
						"group relative flex flex-col items-center rounded-xl border p-3 text-center transition-all sm:p-4",
						cert.highlight
							? "border-yellow-500/30 bg-yellow-500/5 hover:border-yellow-500/60 hover:shadow-md hover:shadow-yellow-500/10"
							: "border-accent/10 bg-accent/5 hover:border-accent/30 hover:shadow-md",
						cert.status === "expired" && "opacity-50 grayscale",
					]}
				>
					{cert.highlight && (
						<span class="absolute -right-1.5 -top-1.5 rounded-full bg-yellow-500 px-1.5 py-0.5 text-[9px] font-bold text-yellow-950">
							🏆
						</span>
					)}
					<img
						src={cert.img}
						alt={cert.name}
						class="mb-2 h-16 w-16 object-contain transition-transform group-hover:scale-110 sm:h-20 sm:w-20"
						loading="lazy"
					/>
					<p class="text-xs font-semibold leading-tight text-textColor/90">
						{cert.label || cert.name}
					</p>
					<p class="mt-0.5 text-[10px] text-textColor/50">{cert.issuer}</p>
					<p class="mt-1 text-[9px] font-medium"
						class:list={{
							"text-green-500/70": cert.status === "active",
							"text-red-400/70": cert.status === "expired",
						}}
					>
						{cert.date}
					</p>
				</a>
			))}
		</div>
	</section>

	<!-- Tags Cloud -->
	<section class="mb-12">
		<h2 class="title mb-4 text-lg font-semibold">Topik Populer</h2>
		<div class="flex flex-wrap gap-2">
			{
				tagsWithCount.map(([tag, count]) => (
					<a
						class="inline-flex items-center gap-1.5 rounded-full border border-accent/20 px-3 py-1.5 text-xs font-medium text-textColor/70 transition-all hover:border-accent hover:bg-accent/10 hover:text-accent"
						href={`/tags/${tag}/`}
					>
						#{tag}
						<span class="text-[10px] text-textColor/40">({count})</span>
					</a>
				))
			}
		</div>
	</section>

	<!-- Featured Post -->
	{
		featured && (
			<section class="mb-12">
				<h2 class="title mb-4 text-lg font-semibold">🌟 Featured</h2>
				<a
					href={`/posts/${featured.slug}/`}
					class="group block rounded-xl border border-accent/20 bg-gradient-to-br from-accent/5 to-transparent p-5 transition-all hover:border-accent/40 hover:shadow-md sm:p-6"
				>
					<div class="flex items-start justify-between gap-4">
						<div class="flex-1">
							<h3 class="mb-2 text-lg font-bold text-accent group-hover:underline sm:text-xl">
								{featured.data.title}
							</h3>
							<p class="mb-3 line-clamp-2 text-sm text-textColor/70">
								{featured.data.description}
							</p>
							<div class="flex flex-wrap items-center gap-3 text-xs text-textColor/50">
								<span>
									<FormattedDate date={featured.data.publishDate} />
								</span>
								{featured.data.tags?.length && (
									<div class="flex gap-1.5">
										{featured.data.tags.slice(0, 3).map((tag) => (
											<span class="rounded-full border border-accent/15 px-2 py-0.5 text-[10px] text-accent">
												#{tag}
											</span>
										))}
									</div>
								)}
							</div>
						</div>
						<span class="hidden text-2xl sm:block">&rarr;</span>
					</div>
				</a>
			</section>
		)
	}

	<!-- Latest Posts -->
	<section aria-label="Blog post list">
		<div class="mb-4 flex items-center justify-between">
			<h2 class="title text-lg font-semibold">Tulisan Terbaru</h2>
			<a class="text-xs font-medium text-accent hover:underline" href="/posts/">
				Lihat semua &rarr;
			</a>
		</div>
		<ul class="divide-y divide-accent/10">
			{
				latestPosts.map((p) => {
					const postDate = p.data.updatedDate ?? p.data.publishDate;
					return (
						<li class="grid gap-x-4 gap-y-1 py-4 sm:grid-cols-[120px_1fr]">
							<FormattedDate
								class="min-w-[120px] text-gray-600 dark:text-gray-400"
								date={postDate}
							/>
							<div>
								{p.data.draft && <span class="text-red-500">(Draft) </span>}
								<a
									class="cactus-link font-medium"
									data-astro-prefetch
									href={`/posts/${p.slug}/`}
								>
									{p.data.title}
								</a>
								<p class="mt-1 line-clamp-2 text-sm text-textColor/60">
									{p.data.description}
								</p>
							</div>
						</li>
					);
				})
			}
		</ul>
	</section>
</PageLayout>
