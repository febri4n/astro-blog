---
interface Props {
  name: string;
  description: string;
  link: string;
  tags: string[];
  private: boolean;
  active?: boolean;
}

const { name, description, link, tags, private: isPrivate, active } = Astro.props;
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  class="group relative flex flex-col gap-3 rounded-lg border border-accent/10 bg-accent/5 p-5 transition-all hover:border-accent/30 hover:shadow-sm"
>
  <div class="absolute end-2 top-2 flex items-center gap-1.5">
    {active && (
      <span class="animate-pulse rounded-md border border-green-500/30 bg-green-500/10 px-2 py-0.5 text-[10px] font-semibold text-green-600 dark:text-green-400">
        Active
      </span>
    )}
    {isPrivate ? (
      <span class="rounded-md border border-orange-500/30 bg-orange-500/10 px-2 py-0.5 text-[10px] font-semibold text-orange-500/90">
        Private
      </span>
    ) : (
      <span class="rounded-md border border-blue-500/30 bg-blue-500/10 px-2 py-0.5 text-[10px] font-semibold text-blue-500">
        Public
      </span>
    )}
  </div>
  <p class="pe-24 font-semibold text-textColor group-hover:text-accent transition-colors">
    {name}
  </p>
  <p class="text-xs leading-relaxed text-textColor/60">
    {description}
  </p>
  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <span class="rounded-full border border-accent/15 bg-accent/10 px-2 py-0.5 text-[10px] font-medium text-accent/80">
        {tag}
      </span>
    ))}
  </div>
  <p class="mt-auto pt-1 text-[11px] text-accent/60 group-hover:text-accent transition-colors">
    {name.startsWith("loker") ? "Website ↗" : "GitHub ↗"}
  </p>
</a>
